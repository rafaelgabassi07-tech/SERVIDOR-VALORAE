{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://valorae.app/contracts/checkpoint114/shared-runtime-state.json",
  "title": "VALORAE Shared Runtime State Manifest",
  "type": "object",
  "required": [
    "status",
    "endpoint",
    "version",
    "policyVersion",
    "implementation",
    "enabled",
    "driver",
    "hiddenFromUi",
    "contractImpact",
    "storage",
    "sharedNamespaces",
    "guarantees",
    "rollback",
    "metrics"
  ],
  "properties": {
    "status": { "const": "OK" },
    "endpoint": { "const": "contract/shared-state" },
    "version": { "const": "2026.07.15-checkpoint114-v1" },
    "policyVersion": { "const": "supabase-shared-runtime-state-memory-fallback-v1" },
    "implementation": { "const": "supabase-rest-memory-mirror-leases-v1" },
    "enabled": { "type": "boolean" },
    "mode": { "type": "string" },
    "driver": { "enum": ["off", "memory", "memory-fallback", "supabase"] },
    "hiddenFromUi": { "const": true },
    "contractImpact": { "const": "none-financial-contract-preserved" },
    "storage": {
      "type": "object",
      "required": ["remote", "localMirror", "scope", "table", "remoteConfigured", "migration"],
      "properties": {
        "remoteConfigured": { "type": "boolean" },
        "scope": { "type": "string", "minLength": 1 },
        "table": { "const": "valorae_runtime_shared_state" },
        "migration": { "const": "supabase/004_valorae_runtime_shared_state_checkpoint114.sql" }
      },
      "additionalProperties": true
    },
    "sharedNamespaces": {
      "type": "object",
      "required": ["contractContinuity", "providerHealth", "negativeFailureCache", "leases"]
    },
    "guarantees": {
      "type": "object",
      "required": [
        "crossInstanceContractContinuity",
        "crossInstanceProviderHealth",
        "sharedNegativeFailureBackoff",
        "expiringStateWithTtl",
        "atomicLeaseSupport",
        "boundedMemoryMirror",
        "remoteFailureNeverBlocksFinancialResponse",
        "memoryFallbackAvailable",
        "serviceRoleNeverExposedToApk",
        "financialPayloadShapeUnchanged",
        "supabaseUserSyncTablesUntouched"
      ],
      "additionalProperties": { "type": "boolean" }
    },
    "rollback": {
      "type": "object",
      "required": ["disable", "memoryOnly", "automatic"]
    },
    "metrics": { "type": "object" }
  },
  "additionalProperties": true
}
