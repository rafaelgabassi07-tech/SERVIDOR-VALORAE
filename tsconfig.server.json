{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist-server",
    "rootDir": ".",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": ["api/**/*.ts", "lib/**/*.js", "server.ts"],
  "exclude": ["node_modules", "src"]
}
