# VALORAE Proxy v21.5.13 — exemplo seguro de variáveis de ambiente
# Copie para .env.local apenas em desenvolvimento local.
# Não coloque tokens, senhas ou URLs privadas reais neste arquivo.

# Deploy / base pública
VALORAE_PUBLIC_BASE_URL=https://seu-proxy.vercel.app
PUBLIC_BASE_URL=

# CORS
# Em produção aberta para apps terceiros, mantenha strict desligado ou configure uma allowlist.
VALORAE_CORS_STRICT=0
VALORAE_CORS_ALLOW_ORIGINS=*

# Rate limit em memória
VALORAE_RATE_LIMIT_MAX=90
VALORAE_RATE_LIMIT_WINDOW_MS=60000
VALORAE_RATE_LIMIT_DISABLED=0
VALORAE_RATE_LIMIT_FORCE_DISABLE=0

# Limites de segurança
VALORAE_MAX_BODY_BYTES=524288
VALORAE_MAX_URL_LENGTH=4096
VALORAE_MAX_QUERY_PARAMS=80
VALORAE_SERVER_MAX_BODY_BYTES=1048576

# Scrape / fontes externas
VALORAE_SCRAPE_URL=
VALORAE_ALLOWED_SCRAPE_HOSTS=
VALORAE_ALLOW_CLIENT_SCRAPE_URL=0
VALORAE_FETCH_TIMEOUT_MS=12000
VALORAE_MAX_HTML_CHARS=3200000
VALORAE_MAX_HTML_HARD_LIMIT=4500000
VALORAE_USER_AGENT=Mozilla/5.0 (compatible; ValoraeProxy/21.5.13; +https://seu-proxy.vercel.app)
VALORAE_ACCEPT_LANGUAGE=pt-BR,pt;q=0.9,en-US;q=0.8,en;q=0.7
VALORAE_SCRAPE_TARGET_USER_AGENT=
VALORAE_INTERNAL_API_TIMEOUT_MS=7000

# Cache em memória / mercado
VALORAE_CACHE_DRIVER=memory
VALORAE_BCB_CACHE_TTL_MS=3600000
VALORAE_BCB_CACHE_STALE_MS=86400000
VALORAE_INDICES_CACHE_TTL_MS=30000
VALORAE_INDICES_CACHE_STALE_MS=300000
VALORAE_I10_RANKINGS_CACHE_TTL_MS=900000
VALORAE_I10_RANKINGS_CACHE_STALE_MS=3600000
VALORAE_YAHOO_HISTORY_TTL_MS=60000
VALORAE_YAHOO_HISTORY_STALE_MS=600000
VALORAE_YAHOO_QUOTE_TTL_MS=20000
VALORAE_YAHOO_QUOTE_STALE_MS=120000

# Limites por rota
VALORAE_RATE_LIMIT_HEALTH_MAX=180
VALORAE_RATE_LIMIT_ASSET_MAX=120
VALORAE_RATE_LIMIT_ASSETS_MAX=80
VALORAE_RATE_LIMIT_HISTORY_MAX=90
VALORAE_RATE_LIMIT_DIVIDENDS_MAX=90
VALORAE_RATE_LIMIT_COMPARE_MAX=70
VALORAE_RATE_LIMIT_MARKET_MAX=90
VALORAE_RATE_LIMIT_NEWS_MAX=90
VALORAE_RATE_LIMIT_SCRAPE_MAX=60
VALORAE_RATE_LIMIT_BATCH_SCRAPE_MAX=40
VALORAE_RATE_LIMIT_COMPAT_MAX=80
VALORAE_RATE_LIMIT_PORTFOLIO_MAX=60
VALORAE_RATE_LIMIT_WATCHLIST_MAX=70
VALORAE_RATE_LIMIT_SYNC_MAX=30
VALORAE_OBSERVABILITY_RATE_LIMIT_MAX=240

# Portfólio / watchlist / batch
VALORAE_PORTFOLIO_MAX_POSITIONS=80
VALORAE_PORTFOLIO_CONCURRENCY=4
VALORAE_PORTFOLIO_HISTORY_MAX_POSITIONS=30
VALORAE_PORTFOLIO_DIVIDENDS_MAX_TICKERS=30
VALORAE_WATCHLIST_MAX_TICKERS=30
VALORAE_COMPARE_MAX_TICKERS=12
VALORAE_RANKING_MAX_TICKERS=15
VALORAE_MAX_BATCH_JOBS=20
VALORAE_BATCH_SCRAPE_CONCURRENCY=4

# Resiliência
VALORAE_CIRCUIT_FAILURE_THRESHOLD=4
VALORAE_CIRCUIT_COOLDOWN_MS=300000
VALORAE_CIRCUIT_SUCCESS_RESET=2

# Observabilidade local/free-only
VALORAE_OBSERVABILITY_WORKER_CAPACITY=64

# Servidor local Node
VALORAE_PORT=3000
VALORAE_HOST=0.0.0.0

# Admin protegido — deixe vazio para manter desativado
VALORAE_ADMIN_TOKEN=
ADMIN_TOKEN=
VALORAE_ADMIN_RATE_LIMIT_MAX=20
VALORAE_ADMIN_ALLOW_QUERY_TOKEN=0
VALORAE_ADMIN_ALLOW_QUERY_TOKEN_IN_PRODUCTION=0

# Debug — apenas desenvolvimento
VALORAE_VERBOSE_ERRORS=0
