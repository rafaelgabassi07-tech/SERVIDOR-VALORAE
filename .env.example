# VALORAE Proxy - configuração gratuita para GitHub/Vercel
# Não adicione segredos reais neste arquivo.

VALORAE_PUBLIC_BASE_URL=https://servidor-valorae.vercel.app
PUBLIC_BASE_URL=https://servidor-valorae.vercel.app

# Observabilidade do app servidor proxy
VALORAE_METRICS_MAX_EVENTS=320
VALORAE_METRICS_MAX_ROUTES=120
VALORAE_METRICS_MAX_CLIENTS=420
VALORAE_METRICS_MAX_BUCKETS=180
VALORAE_RATE_LIMIT_METRICS_MAX=120

# Rate limit padrão do proxy
VALORAE_RATE_LIMIT_MAX=90

# Integração Web/APK
# O CORS padrão já aceita headers x-valorae-app, x-valorae-channel, x-valorae-app-version,
# x-valorae-build, x-valorae-app-id e x-valorae-client-key para facilitar consumo em navegador/APK.
# Ative modo strict apenas quando já souber os domínios finais do app.
VALORAE_CORS_STRICT=false
VALORAE_CORS_ALLOW_ORIGINS=

# Segurança: manter falso em produção para evitar SSRF.
VALORAE_ALLOW_CLIENT_SCRAPE_URL=false

# v21.11.8 - otimização profunda de scraping/API free-only
VALORAE_SCRAPE_RESULT_CACHE_ENABLED=true
VALORAE_SCRAPE_RESULT_CACHE_TTL_MS=60000
VALORAE_SCRAPE_RESULT_CACHE_MAX_ENTRIES=250
VALORAE_SCRAPE_RESULT_CACHE_MAX_BYTES=16777216
VALORAE_HTML_CACHE_MAX_ENTRIES=200
VALORAE_HTML_CACHE_STALE_MS=300000
VALORAE_FAST_SELECTORS_ENABLED=true
VALORAE_FAST_SELECTORS_MIN_COVERAGE=0.55
VALORAE_BATCH_GROUP_BY_FETCH_KEY=true
VALORAE_HTML_INFLIGHT_DEDUPE=true
VALORAE_DEFAULT_PREVIEW_CHARS=300
VALORAE_ENABLE_FIELDS_PARAM=true
VALORAE_ENABLE_COMPACT_PARAM=true

# v21.11.0 — Engine Core maturity
VALORAE_DIRECT_FETCH_RETRIES=1
VALORAE_CIRCUIT_FAILURE_THRESHOLD=4
VALORAE_CIRCUIT_COOLDOWN_MS=300000

# v21.11.1 — Engine modules, cache familiar e precisão de gráficos
VALORAE_CIRCUIT_SUCCESS_RESET=2
VALORAE_CIRCUIT_WINDOW_LIMIT=40

# v21.11.8 — Engine performance/precision
VALORAE_FAILURE_CACHE_ENABLED=true
VALORAE_FAILURE_CACHE_TTL_MS=12000
VALORAE_FAILURE_CACHE_MAX_ENTRIES=80
VALORAE_ENGINE_STALE_PREFER_SCORE=45
VALORAE_ENGINE_CONSERVATIVE_SCORE=62
VALORAE_ENGINE_DISABLE_DIRECT_RETRY=false

# v21.12.26 — uso pessoal/pessoas próximas
# Mantém o projeto simples e gratuito, mas permite endurecer acesso quando desejar.
VALORAE_PERSONAL_MODE=true

# Recomendado para apps Web/APK finais. Se quiser manter debug antigo como padrão, deixe vazio e envie view=app nas chamadas.
VALORAE_DEFAULT_ASSET_VIEW=app
VALORAE_DEFAULT_ASSETS_VIEW=app

# Autenticação opcional por app/cliente. Exemplo: VALORAE_CLIENT_KEYS=web:chave-forte,apk:outra-chave
VALORAE_CLIENT_KEYS=
VALORAE_REQUIRE_CLIENT_AUTH=false
