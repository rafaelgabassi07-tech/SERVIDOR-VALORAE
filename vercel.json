{
  "version": 2,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        }
      ]
    }
  ],
  "buildCommand": "node scripts/build-vercel-safe.js",
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/router?path="
    },
    {
      "source": "/api/:path*",
      "destination": "/api/router?path=:path*"
    },
    {
      "source": "/",
      "destination": "/server.html"
    },
    {
      "source": "/server",
      "destination": "/server.html"
    },
    {
      "source": "/tests",
      "destination": "/server.html"
    },
    {
      "source": "/inspector",
      "destination": "/server.html"
    }
  ]
}